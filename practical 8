EXTERNAL CSS
 body {
    margin: 0;
    font-family: Arial;
    background: linear-gradient(to right, #4facfe, #00f2fe);
}

.title {
    text-align: center;
    color: white;
    padding: 20px;
}

.gallery {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 20px;
    padding: 20px;
}

.card {
    overflow: hidden;
    border-radius: 10px;
    transition: transform 0.3s ease;
}

.card img {
    width: 300px;
    height: 200px;
    display: block;
    transition: transform 0.5s ease, filter 0.5s ease;
}

/* Hover Effects */
.card:hover {
    transform: scale(1.1);
}

.card:hover img {
    transform: scale(1.2);
    filter: brightness(70%);
}
